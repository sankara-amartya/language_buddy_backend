# App
PORT=3000
NODE_ENV=development

# Notification API auth for external applications
NOTIFICATION_AUTH_TOKEN=replace-with-strong-token

# Redis for queue and worker
REDIS_URL=redis://127.0.0.1:6379

# WhatsApp Cloud API
WHATSAPP_TOKEN=replace-with-meta-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id
WHATSAPP_API_VERSION=v22.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-webhook-verify-token
WHATSAPP_APP_SECRET=replace-with-whatsapp-app-secret
WHATSAPP_WEBHOOK_VALIDATE_SIGNATURE=true

# Notification behavior
NOTIFICATION_RETRY_ATTEMPTS=5
NOTIFICATION_BACKOFF_MS=2000
NOTIFICATION_QUEUE_RATE_LIMIT_MAX=30
NOTIFICATION_QUEUE_RATE_LIMIT_DURATION_MS=1000
ENABLE_ERROR_NOTIFICATIONS=false

# Optional: admin number to receive backend 5xx alerts
ALERT_ADMIN_PHONE_E164=+15551234567

# User and delivery storage paths (JSON file storage for this starter implementation)
# data/users.json
# data/notification-deliveries.json
